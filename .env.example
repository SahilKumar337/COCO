# WALL-E AI — Environment Variables
# Copy this to .env and fill in your values.
# On Raspberry Pi, the installer (deploy/pi/install.sh) does this automatically.
# Created by K.Astra and its members.

# ─── Required ────────────────────────────────────────────────────────────────
# Your Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
# Set to "production" to enable JSON logging and disable auto-open browser
ENVIRONMENT=development

# ─── User Defaults ───────────────────────────────────────────────────────────
WALLE_USER_NAME=K.Astra
WALLE_VOICE=Aoede
WALLE_PERSONA=Professional Executive Assistant

# ─── Owner (Hardware / Pi Mode) ──────────────────────────────────────────────
WALLE_OWNER_NAME=Sahil
WALLE_OWNER_REF_FILE=sahil_reference.wav

# ─── Database (Optional) ─────────────────────────────────────────────────────
# Leave unset to use local SQLite (walle_memory.db).
# For Railway/Render/production, set to your PostgreSQL URL:
# DATABASE_URL=postgres://user:password@host:port/dbname

# ─── Raspberry Pi 5 Settings (auto-set by install.sh) ────────────────────────
# WALLE_PI_MODE=1              # Force Pi mode (usually auto-detected)
# WALLE_AUDIO_BLOCKSIZE=4096   # Larger block = fewer ALSA underruns on ARM
# WALLE_MIC_DEVICE=USB Audio   # Mic: name substring or device index number
# WALLE_SPEAKER_DEVICE=        # Speaker: name substring or device index (blank = ALSA default)
# WALLE_WHISPER_MODEL=tiny     # Wake word model: tiny | base | small
# WALLE_WHISPER_COMPUTE=int8   # int8 = fastest ARM inference, less memory
# WALLE_TORCH_THREADS=2        # PyTorch CPU threads (Pi 5 has 4 cores)
# WALLE_FACE_INTERVAL=3.0      # Seconds between face detections (higher = lower CPU)
# WALLE_CAM_W=320              # Camera capture width (lower = faster on Pi)
# WALLE_CAM_H=240              # Camera capture height
