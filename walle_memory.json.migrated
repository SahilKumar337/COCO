    "turns": [
      {
        "role": "assistant",
        "content": "\u092f\u093e\u0930, \u092f\u0939\u092c\u093e\u0924\u092d\u0940 \u092e\u0941\u091d\u0947\u0920\u0940\u0915\u0938\u0947 \u0926\u093f\u0916\u093e\u0908\u0928\u0939\u0940\u0902 \u0926\u0947\u0930\u0939\u0940\u0964\u092e\u0947\u0930\u0947\u0938\u0947\u0902\u0938\u0930\u094d\u0938\u092e\u0947\u0902 \u0925\u094b\u0921\u093c\u0940\u0926\u093f\u0915\u094d\u0915\u0924\u0932\u0917 \u0930\u0939\u0940\u0939\u0948 \u0907\u0938\u092c\u093e\u0930\u0947\u092e\u0947\u0902\u0964\u0906\u092a \u0939\u0940\u092c\u0924\u093e \u0926\u094b,\u0915\u094d\u092f\u093e \u0938\u091a\u092e\u0947\u0902 \u092a\u0940\u0932\u0940\u091f\u0940-\u0936\u0930\u094d\u091f\u092a\u0939\u0928\u0940\u0939\u0948 \u0909\u0928\u094d\u0939\u094b\u0902\u0928\u0947?"
      },
      {
        "role": "user",
        "content": "\u092f\u0939 \u0924\u094b \u0916\u093e\u0932\u093f\u0926 \u092d\u0948\u092f\u093e \u0915\u0940 \u0939\u093e\u0907\u091f \u0915\u093f\u0924\u0928\u0940 \u0939\u0948? \u0916\u093e\u0932\u093f\u0926 \u0924\u094b \u0924\u0941\u092e\u094d\u0939\u093e\u0930\u0947 \u092e\u0939\u093e\u0930\u093e\u091c \u0939\u0948, \u0909\u0928\u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u0924\u094b \u0924\u0941\u092e\u094d\u0939\u0947\u0902 \u092a\u0924\u093e \u0939\u094b\u0928\u093e \u091a\u093e\u0939\u093f\u090f\u0964"
      },
      {
        "role": "assistant",
        "content": "\u092e\u0939\u093e\u0930\u093e\u091c \u0916\u093e\u0932\u093f\u0926\u0915\u0940 \u0939\u093e\u0907\u091f\u0915\u0947 \u092c\u093e\u0930\u0947\u092e\u0947\u0902 \u092e\u0941\u091d\u0947\u0920\u0940\u0915\u0921\u0947\u091f\u093e\u0928\u0939\u0940\u0902\u0939\u0948\u0964\u092f\u093e\u0930,\u092e\u0948\u0902 \u0915\u094b\u0908\u092e\u0947\u091c\u0930\u093f\u0902\u0917\u091f\u0947\u092a\u0925\u094b\u0921\u093c\u0940\u0939\u0942\u0901!\ud83d\ude04 \u092e\u0941\u091d\u0947\u0909\u0928\u0915\u0940\u0939\u093e\u0907\u091f\u0915\u093e \u0905\u0902\u0926\u093e\u091c\u093c\u093e\u0928\u0939\u0940\u0902 \u092e\u093f\u0932\u092a\u093e \u0930\u0939\u093e\u0964\u0915\u094d\u092f\u093e\u0906\u092a \u092c\u0924\u093e\u0938\u0915\u0924\u0947\u0939\u0948\u0902?"
      },
      {
        "role": "user",
        "content": "\u0916\u093e\u0932\u093f\u0926 \u092d\u0948\u092f\u093e \u092d\u0940 6 \u092e\u0939\u0940\u0928\u0947 \u0915\u0947 \u092c\u091a\u094d\u091a\u0947 \u0939\u0948\u0902\u0964"
      },
      {
        "role": "assistant",
        "content": "6 \u092e\u0939\u0940\u0928\u0947\u0915\u0947 \u092c\u091a\u094d\u091a\u0947?Haha!\u0915\u094d\u092f\u093e\u092c\u093e\u0924\u0915\u0930 \u0930\u0939\u0947\u0939\u094b!\u0907\u0924\u0928\u0947\u092c\u0941\u0926\u094d\u0927\u093f\u092e\u093e\u0928\u092e\u0939\u093e\u0930\u093e\u091c6 \u092e\u0939\u0940\u0928\u0947\u0915\u0947?\u0924\u0941\u092e \u0924\u094b\u092c\u0921\u093c\u0947\u092e\u091c\u093c\u093e\u0915\u093f\u092f\u093e\u0939\u094b!\u0915\u0941\u091b\u0914\u0930 \u092c\u0924\u093e\u0913\u0907\u0928\u0915\u0947\u092c\u093e\u0930\u0947\u092e\u0947\u0902\u0964"
